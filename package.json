{
  "name": "neural-playground",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "dev:web": "npm run dev --workspace @neural-playground/web",
    "setup": "sh scripts/setup_prune_venv.sh",
    "dev:prune-service": "sh scripts/setup_prune_venv.sh && npm run dev --workspace @neural-playground/prune-service",
    "test:v1": "npm run build --workspace @neural-playground/test-suite && npm run test --workspace @neural-playground/test-suite",
    "test:e2e": "npm run test:e2e --workspace @neural-playground/web",
    "test:all": "npm run test:v1 && npm run test:e2e"
  }
}
