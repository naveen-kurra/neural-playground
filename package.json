{
  "name": "neural-playground",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "dev:web": "npm run dev --workspace @neural-playground/web",
    "dev:prune-service": "npm run dev --workspace @neural-playground/prune-service"
  }
}
